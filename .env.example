# MongoDB Atlas — create a free cluster at https://cloud.mongodb.com
MONGODB_URI=

# Firebase Admin SDK — in Firebase Console: Project Settings > Service Accounts > Generate New Private Key
# The FIREBASE_PRIVATE_KEY value must be the full PEM string including -----BEGIN PRIVATE KEY-----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Cloudinary — create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Server port
PORT=5000
